# Local development variables for Cloudflare Workers bindings.
# This file is NOT committed to git (it is in .gitignore).
# The actual secrets (AUTH_USERNAME, AUTH_PASSWORD, AUTH_SECRET) must be set
# with `wrangler secret put` for the deployed environment.
# For local dev, wrangler will use the bindings defined in wrangler.jsonc
# and these vars for environment variables.
NEXTJS_ENV=development
